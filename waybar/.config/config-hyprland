{
    "layer": "top",
    "height": 30,
    "position": "top",
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "custom/wf-recorder"
    ],
    "modules-right": [
        "hyprland/language",
        "idle_inhibitor",
        "cpu",
        "memory",
        "battery",
        "network",
        "custom/v2raya",
        "bluetooth",
        "pulseaudio",
        "backlight",
        "tray",
        "clock"
    ],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "sort-by-number": true,
        "on-click": "activate",
        "format": "{name}"
    },

    "hyprland/language": {
        "format": "{}",
        "format-en": "US",
        "format-ru": "RU",
        "min-length": 2,
        "tooltip": false,
        "on-click": "hyprctl switchxkblayout all next"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "󰒳",
            "deactivated": "󰒲"
        }
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format-charging": "󰂄 {capacity}%",
        "format": "{icon} {capacity}%",
        "format-icons": ["󱃍", "󰁺", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"]
    },

    "clock": {
        "interval": 60,
        "format": "{:%e %b %Y %H:%M}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>"
    },

    "cpu": {
        "interval": 10,
        "format": "󰘚 {usage}%",
        "on-click": "footclient -a btop -e btop"
    },

    "memory": {
        "interval": 10,
        "format": "󰍛 {percentage}%",
        "on-click": "footclient -a btop -e btop"
    },

    "network": {
        "interval": 5,
        "format-wifi": "{icon}",
        "format-ethernet": "󰈀",
        "format-disconnected": "󰖪",
        "format-disabled": "󰀝",
        "format-icons": ["󰤯", "󰤟", "󰤢", "󰤥", "󰤨"],
        "tooltip-format-wifi": "{icon} {essid}: {ipaddr}",
        "tooltip-format-ethernet": "{icon} {ifname}: {ipaddr}",
        "tooltip-format-disconnected": "Disconnected",
        "tooltip-format-disabled": "Disabled",
        "on-click": "$HOME/.config/hypr/scripts/wifi-menu.sh"
    },

    "custom/v2raya": {
        "format": "{}",
        "return-type": "json",
        "exec": "/home/yegor/.config/waybar/scripts/v2raya-status.sh",
        "interval": 5,
        "on-click": "footclient -a v2raya-tui -e /home/yegor/projects/v2raya-tui/target/debug/v2raya-tui",
        "on-click-right": "/home/yegor/.config/waybar/scripts/v2raya-toggle.sh",
        "tooltip": true
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"]
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%",
        "format-muted": "󰖁",
        "format-icons": {
            "headphone": "󰋋",
            "headset": "󰋎",
            "default": ["󰕿", "󰖀", "󰕾"]
        }
    },

    "tray": {
        "icon-size": 16,
        "spacing": 5
    },

    "bluetooth": {
        "format": "󰂯",
        "format-disabled": "󰂲"
    },

    "custom/wf-recorder": {
        "interval": "once",
        "return-type": "json",
        "format": "{}",
        "exec": "echo '{\"class\": \"recording\",\"text\":\"󰑊\",\"tooltip\":\"Press Super+Esc to stop\"}'",
        "exec-if": "pgrep wf-recorder",
        "signal": 8
    }
}