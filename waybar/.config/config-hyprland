{
    "layer": "top",
    "height": 30,
    "position": "top",
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "custom/wf-recorder"
    ],
    "modules-right": [
        "hyprland/language",
        "idle_inhibitor",
        "cpu",
        "memory",
        "battery",
        "network",
        "bluetooth",
        "pulseaudio",
        "backlight",
        "tray",
        "clock"
    ],

    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "sort-by-number": true,
        "on-click": "activate",
        "format": "{icon}",
        "format-icons": {
            "urgent": "ο¹Σ",
            "active": "οÜ£",
            "default": "ο³ë"
        }
    },

    "hyprland/submap": {
        "format": "<span style=\"italic\">{}</span>",
        "tooltip": false
    },

    "hyprland/language": {
        "format": "{}",
        "format-en": "US",
        "format-ru": "RU",
        "min-length": 2,
        "tooltip": false,
        "on-click": "hyprctl switchxkblayout all next"
    },

    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "σΑ£≥",
            "deactivated": "σΑ£≤"
        },
        "tooltip": true,
        "tooltip-format-activated": "Screen lock disabled",
        "tooltip-format-deactivated": "Screen lock enabled"
    },

    "battery": {
        "interval": 30,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format-charging": "σΑ²³ {capacity}%",
        "format": "{icon} {capacity}%",
        "format-icons": ["σ±Éç", "σΑ¹Κ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
        "tooltip": true
    },

    "clock": {
        "interval": 60,
        "format": "{:%e %b %Y %H:%M}",
        "tooltip": true,
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt>{calendar}</tt>",
        "on-click": "footclient -e calcurse"
    },

    "cpu": {
        "interval": 10,
        "format": "σΑ‰ö {usage}%",
        "states": {"warning": 70, "critical": 90},
    },

    "memory": {
        "interval": 10,
        "format": "σΑç¦ {percentage}%",
        "states": {"warning": 70, "critical": 90},
    },

    "network": {
        "interval": 5,
        "format-wifi": "{icon}",
        "format-ethernet": "σΑàÄ",
        "format-disconnected": "σΑ•Σ",
        "format-disabled": "σΑÄù",
        "format-icons": ["σΑΛ·", "σΑΛü", "σΑΛΔ", "σΑΛΞ", "σΑΛ®"],
        "tooltip-format": "{icon} {ifname}: {ipaddr}",
        "on-click": "$HOME/.config/hypr/scripts/wifi-menu.sh"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up": "brightnessctl -e4 -n2 set 5%+",
        "on-scroll-down": "brightnessctl -e4 -n2 set 5%-"
    },

    "pulseaudio": {
        "scroll-step": 5,
        "format": "{icon} {volume}%{format_source}",
        "format-muted": "σΑ•¹ {format_source}",
        "format-source": "",
        "format-source-muted": " σΑç≠",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "headset": "σΑ΄é",
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "on-click": "footclient -e pulsemixer",
        "on-click-middle": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "on-scroll-up": "wpctl set-volume -l 1.0 @DEFAULT_AUDIO_SINK@ 5%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 5
    },

    "bluetooth": {
        "format": "σΑ²·",
        "format-disabled": "σΑ²≤",
        "on-click": "$HOME/.config/hypr/scripts/bluetooth-menu.sh",
        "on-click-right": "rfkill toggle bluetooth",
        "tooltip-format": "{}"
    },

    // Custom script for displaying screen recording indicator
    "custom/wf-recorder": {
        "interval": "once",
        "return-type": "json",
        "format": "{}",
        "exec": "echo '{\"class\": \"recording\",\"text\":\"σΑëä\",\"tooltip\":\"Press Super+Esc to stop\"}'",
        "exec-if": "pgrep wf-recorder",
        "signal": 8
    }
}
