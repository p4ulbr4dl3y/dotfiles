# --- FONT AND POSITION SETTINGS ---
font=JetBrainsMono NF 11
width=350
height=150
margin=20,20,20,20
# Position: notifications will appear in the top-right corner
anchor=top-right

# --- APPEARANCE (Catppuccin Mocha Blue) ---
# Base background
background-color=#1e1e2e
# Text color
text-color=#cdd6f4
# Blue accent
border-color=#89b4fa
border-size=2
border-radius=12
padding=15

# --- BEHAVIOR ---
# How many notifications to show at once
max-visible=5
# Display time for normal notifications (in milliseconds) -> 5 seconds
default-timeout=5000
# Text format: Bold title, normal text below
markup=1
format=<b>%s</b>\n%b

# --- ICONS ---
icons=1
max-icon-size=48
icon-path=/usr/share/icons/Papirus-Dark

# --- CRITICAL NOTIFICATION RULES ---
# Critical notifications with red border (Red), disappear after 3 seconds
[urgency=high]
border-color=#f38ba8
default-timeout=3000
ignore-timeout=0
